# Dataset roots
ATTDS_RAW_ROOT=C:\path\to\raw_dicom
ATTDS_DATA_ROOT=C:\path\to\anon_dig
ATTDS_MANUAL_DIR=C:\path\to\manual_masks

# TotalSegmentator executable; "TotalSegmentator" works if it is on PATH.
ATTDS_TS_EXE=TotalSegmentator

# Optional output/configuration paths
ATTDS_DL_DIR=C:\path\to\anon_dig\dl_preds
ATTDS_L3_SLICES_DIR=C:\path\to\annotations\nii_for_snap
ATTDS_OVERLAY_DIR=C:\path\to\overlays
ATTDS_MODEL_WEIGHTS=C:\path\to\anon_dig\dl_runs\l3_unet_best.pt

# Streamlit app overrides
APP_ROOT=C:\path\to\anon_dig
APP_MANUAL_DIR=C:\path\to\manual_masks
APP_DL_DIR=C:\path\to\anon_dig\dl_preds
APP_TS_SUBDIR=segmentations2_tissue
APP_WEIGHTS=C:\path\to\anon_dig\dl_runs\l3_unet_best.pt
